<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>codex.fs.cli</PackageId>
    <Version>0.1.0-alpha.5</Version>
    <Authors>ingted</Authors>
    <Company>ingted</Company>
    <Description>Terminal client command surface for codex.fs host/session control.</Description>
    <PackageTags>fsharp;codex;agents;ptcs;cli;argu</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/ingted/codex.fs</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/ingted/codex.fs</PackageProjectUrl>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>codex.fs.cli</ToolCommandName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="FAkka.Argu" Version="[10.1.301]" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\codex.fs.host\codex.fs.host.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Cli.fs" />
    <Compile Include="CliHttp.fs" />
    <Compile Include="ProgramCore.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

</Project>
